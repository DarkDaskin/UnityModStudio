<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <ProjectCapability Include="UnityModStudio.RimWorld" />
  </ItemGroup>

  <PropertyGroup>
    <SteamAppId>294100</SteamAppId>
    <GameModsPath>Mods\</GameModsPath>
    <AssetsFolderName>Assets</AssetsFolderName>
  </PropertyGroup>

  <PropertyGroup>
    <ModSourcePath Condition="Exists('..\About\About.xml')">..\</ModSourcePath>
    <ModSourcePath Condition="Exists('..\..\About\About.xml')">..\..\</ModSourcePath>
    <ModSourcePath Condition="Exists('$(AssetsFolderName)\About\About.xml')">$(AssetsFolderName)\</ModSourcePath>
  </PropertyGroup>
</Project>